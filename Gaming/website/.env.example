# Sanity environment variables
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_ORGANIZATION_ID=your_sanity_organization_id_here

# Sanity write token — generate at https://sanity.io/manage → project → API → Tokens → Add Token (Editor role)
SANITY_API_TOKEN=your_sanity_editor_token_here

# NVIDIA NIM API Key (for AI blog generation)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Hugging Face Access Token (for AI image generation)
HF_TOKEN=your_huggingface_token_here
