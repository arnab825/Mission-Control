{
    "name":  "mission-control",
    "productName":  "Mission Control",
    "private":  true,
    "version":  "1.2.1",
    "description":  "Mission Control desktop app for gamers.",
    "author":  "Arnab Contributors \u003csupport@missioncontrol.app\u003e",
    "type":  "module",
    "main":  "dist-electron/main.cjs",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "lint":  "eslint .",
                    "preview":  "vite preview",
                    "test":  "vitest",
                    "test:run":  "vitest run",
                    "package":  "electron-forge package",
                    "make":  "electron-forge make",
                    "doctor":  "react-doctor",
                    "postinstall":  "node patch-nsis.mjs"
                },
    "devDependencies":  {
                            "@clerk/clerk-react":  "^4.19.0",
                            "@electron-forge/cli":  "^7.11.2",
                            "@electron-forge/maker-deb":  "^7.11.2",
                            "@electron-forge/maker-rpm":  "^7.11.2",
                            "@electron-forge/maker-squirrel":  "^7.11.2",
                            "@electron-forge/shared-types":  "^7.11.2",
                            "@eslint/js":  "^10.0.1",
                            "@tailwindcss/vite":  "^4.3.0",
                            "@testing-library/dom":  "^10.4.1",
                            "@testing-library/jest-dom":  "^6.9.1",
                            "@testing-library/react":  "^16.3.2",
                            "@types/node":  "^24.12.3",
                            "@types/react":  "^19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^6.0.1",
                            "clsx":  "^2.1.1",
                            "electron":  "^42.1.0",
                            "electron-builder":  "^26.15.3",
                            "electron-forge-maker-nsis":  "^26.15.3",
                            "electron-updater":  "^6.8.9",
                            "eslint":  "^10.3.0",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-react-refresh":  "^0.5.2",
                            "framer-motion":  "^12.38.0",
                            "fuse.js":  "^7.3.0",
                            "globals":  "^17.6.0",
                            "healthchecks":  "^1.7.3",
                            "jsdom":  "^29.1.1",
                            "lucide-react":  "^0.469.0",
                            "react":  "^19.2.6",
                            "react-doctor":  "^0.2.11",
                            "react-dom":  "^19.2.6",
                            "recharts":  "^2.15.0",
                            "tailwind-merge":  "^3.6.0",
                            "typescript":  "~6.0.2",
                            "typescript-eslint":  "^8.59.2",
                            "vite":  "^8.0.12",
                            "vite-plugin-electron":  "^0.29.1",
                            "vite-plugin-electron-renderer":  "^0.14.7",
                            "vitest":  "^4.1.7"
                        },
    "build":  {
                  "compression":  "maximum",
                  "publish":  {
                                  "provider":  "github",
                                  "owner":  "arnab825",
                                  "repo":  "Mission-Control"
                              },
                  "nsis":  {
                               "oneClick":  true,
                               "allowToChangeInstallationDirectory":  false,
                               "perMachine":  true,
                               "packElevateHelper":  true,
                               "allowElevation":  true,
                               "shortcutName":  "Mission Control",
                               "uninstallDisplayName":  "Mission Control",
                               "runAfterFinish":  true,
                               "include":  "electron/installer.nsh"
                           },
                  "directories":  {
                                      "output":  "out/make"
                                  },
                  "files":  [
                                "**/*",
                                "!backend/**"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "backend",
                                             "to":  "backend"
                                         }
                                     ],
                  "win":  {
                              "icon":  "public/favicon.ico",
                              "requestedExecutionLevel":  "requireAdministrator",
                              "signExecutable":  false,
                              "signtoolOptions":  {
                                                      "sign":  "./sign-dummy.cjs"
                                                  }
                          }
              }
}