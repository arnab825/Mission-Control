{
    "name":  "mission-control",
    "productName":  "Mission Control",
    "private":  true,
    "version":  "2.3.6",
    "description":  "Mission Control desktop app for gamers.",
    "author":  "Arnab Contributors \u003csupport@missioncontrol.app\u003e",
    "type":  "module",
    "main":  "dist-electron/main.cjs",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "lint":  "eslint .",
                    "preview":  "vite preview",
                    "test":  "vitest",
                    "test:run":  "vitest run",
                    "package":  "electron-forge package",
                    "make":  "electron-forge make",
                    "make:win":  "electron-builder --win nsis --x64",
                    "make:win:all":  "electron-builder --win nsis msi zip --x64",
                    "doctor":  "react-doctor",
                    "postinstall":  "node patch-nsis.mjs"
                },
    "devDependencies":  {
                            "@clerk/clerk-react":  "^5.61.3",
                            "@electron-forge/cli":  "^7.11.2",
                            "@electron-forge/maker-deb":  "^7.11.2",
                            "@electron-forge/maker-rpm":  "^7.11.2",
                            "@electron-forge/maker-squirrel":  "^7.11.2",
                            "@electron-forge/shared-types":  "^7.11.2",
                            "@eslint/js":  "^10.0.1",
                            "@tailwindcss/vite":  "^4.3.0",
                            "@testing-library/dom":  "^10.4.1",
                            "@testing-library/jest-dom":  "^6.9.1",
                            "@testing-library/react":  "^16.3.2",
                            "@types/node":  "^26.1.1",
                            "@types/react":  "^19.2.17",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^6.0.3",
                            "clsx":  "^2.1.1",
                            "electron":  "43.1.1",
                            "electron-builder":  "^26.15.3",
                            "electron-forge-maker-nsis":  "^26.15.3",
                            "electron-updater":  "^6.8.9",
                            "eslint":  "^10.7.0",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-react-refresh":  "^0.5.2",
                            "framer-motion":  "^12.38.0",
                            "fuse.js":  "^7.5.0",
                            "globals":  "^17.6.0",
                            "healthchecks":  "^1.7.3",
                            "jsdom":  "^29.1.1",
                            "lucide-react":  "^1.25.0",
                            "react":  "^19.2.7",
                            "react-doctor":  "^0.8.1",
                            "react-dom":  "^19.2.6",
                            "recharts":  "^2.15.0",
                            "tailwind-merge":  "^3.6.0",
                            "typescript":  "~7.0.2",
                            "typescript-eslint":  "^8.64.0",
                            "vite":  "^8.1.5",
                            "vite-plugin-electron":  "^0.29.1",
                            "vite-plugin-electron-renderer":  "^1.0.0",
                            "vitest":  "^4.1.7"
                        },
    "build": {
        "appId": "com.missioncontrol.app",
        "productName": "Mission Control",
        "compression": "maximum",
        "publish": {
            "provider": "github",
            "owner": "arnab825",
            "repo": "Mission-Control"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": true,
            "packElevateHelper": true,
            "allowElevation": true,
            "shortcutName": "Mission Control",
            "runAfterFinish": true,
            "createDesktopShortcut": "always",
            "createStartMenuShortcut": true,
            "license": "electron/license.txt",
            "include": "electron/installer.nsh"
        },
                  "msi":  {
                              "oneClick":  false,
                              "perMachine":  true,
                              "runAfterFinish":  true
                          },
                  "directories":  {
                                      "output":  "out/dist"
                                  },
                  "files":  [
                                "dist/**/*",
                                "dist-electron/**/*",
                                "!backend/**",
                                "!out/**"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "../backend/dist/MissionControl",
                                             "to":  "MissionControl"
                                         },
                                         {
                                             "from":  "app-update.yml",
                                             "to":  "app-update.yml"
                                         }
                                     ],
                  "win":  {
                              "artifactName":  "MissionControl-Setup.${ext}",
                              "icon":  "public/favicon.ico",
                              "verifyUpdateCodeSignature":  false,
                              "requestedExecutionLevel":  "requireAdministrator",
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             },
                                             {
                                                 "target":  "msi",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             },
                                             {
                                                 "target":  "zip",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ]
                          }
              }
}