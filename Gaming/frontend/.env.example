# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Aero AI Gaming Assistant — Frontend Environment Template
#  Copy this file to .env and fill in your own values.
#  NEVER commit .env — it is gitignored.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Clerk Authentication ────────────────────────────────
# Found in your Clerk dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
VITE_CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# ── Bridge Server (optional — defaults shown) ───────────
# VITE_BRIDGE_HOST=localhost
# VITE_BRIDGE_PORT=8765
# VITE_BRIDGE_URL=ws://localhost:8765
